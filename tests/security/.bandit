# Bandit configuration for Python security scanning
# https://bandit.readthedocs.io/en/latest/config.html

[bandit]
# Exclude test files from scanning
exclude_dirs = ['/tests/', '/.venv/', '/venv/', '__pycache__']

# Test IDs to skip
skips = []

# Test IDs to include (empty means all)
tests = []

# Severity level threshold (LOW, MEDIUM, HIGH)
level = LOW

# Confidence level threshold (LOW, MEDIUM, HIGH)
confidence = MEDIUM
